{
  "name": "watchbridge",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "deploy": "npm run build && wrangler pages deploy dist --project-name watchbridge --branch main",
    "dev": "nuxt dev --host 0.0.0.0",
    "lint": "eslint .",
    "postinstall": "nuxt prepare",
    "preview": "npm run build && wrangler pages dev dist",
    "test": "vitest run",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@lucide/vue": "^1.23.0",
    "@tailwindcss/vite": "^4.3.2",
    "jszip": "^3.10.1",
    "nuxt": "^4.4.8",
    "papaparse": "^5.5.4",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260627.0",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/test-utils": "^4.0.3",
    "@types/papaparse": "^5.3.16",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.0.11",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.2.0",
    "wrangler": "^4.106.0"
  }
